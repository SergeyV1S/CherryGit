# ---------------------------------------------------------------------------
# CherryGit backend — пример .env (скопировать в .env и заполнить)
# Источник истины: src/config/env.ts
# ---------------------------------------------------------------------------

# Application Configuration
APPNAME=cherrygit
PORT=8080
NODE_ENV=dev
LOCALE=true
PRODUCTION_URL=api.cherrygit.example
CLIENT_BASE_URL=http://localhost:5173

# Rate limiter settings (брутфорс-защита логина)
LOGIN_RATE_LIMITER_ATTEMPTS=5
LOGIN_RATE_LIMITER_TIMER_M=15

# Database Configuration
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=your_database_password
DATABASE_NAME=cherrygit
DATABASE_URL=postgresql://postgres:your_database_password@127.0.0.1:5432/cherrygit

# JWT Secrets and settings
JWT_ACCESS_SECRET=your_jwt_access_secret
JWT_REFRESH_SECRET=your_jwt_refresh_secret
ACCESS_TOKEN_EXPIRES_IN=15m
# ONLY HOURS!!! 0.5h allowed
REFRESH_TOKEN_EXPIRES_IN=168h

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password

# Шифрование PAT-токенов GitLab (ВКР 2.2.3). 32 байта в hex = 64 символа.
# Генерация: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=replace_with_64_hex_chars

# Sync-планировщик (FR-02), опциональные.
# SYNC_INTERVAL_M — период в минутах (default 10). Используется, если SYNC_CRON пуст.
SYNC_INTERVAL_M=10
# SYNC_CRON — cron-выражение (5 полей), приоритетнее SYNC_INTERVAL_M.
# Пример «по будням каждый час с 9 до 18»: 0 9-18 * * 1-5
SYNC_CRON=
SYNC_RUN_ON_START=false
